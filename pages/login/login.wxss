/* 登录页 — v2.2 暖色调优化 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fdf8f0 0%, #f5ede0 40%, #f0e6d8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* ========================================
   品牌区
   ======================================== */
.brand {
  text-align: center;
  padding-top: 100rpx;
  padding-bottom: 48rpx;
}

.brand__deco {
  font-size: 28rpx;
  color: #c8b89a;
  letter-spacing: 12rpx;
  margin-bottom: 32rpx;
  opacity: 0.7;
}

.brand__icon {
  font-size: 88rpx;
  display: block;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(139, 94, 60, 0.1));
}

.brand__title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 0 rgba(139, 94, 60, 0.08);
}

.brand__desc {
  font-size: 24rpx;
  color: #b8a28a;
  margin-top: 14rpx;
  display: block;
  letter-spacing: 4rpx;
}

/* ========================================
   登录面板
   ======================================== */
.login-panel {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ========================================
   头像选择卡片 — 横向布局
   ======================================== */
.profile-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(139, 94, 60, 0.06);
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.profile-card__left {
  flex-shrink: 0;
  margin-right: 36rpx;
}

.profile-card__right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.avatar-btn {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  position: relative;
  display: block;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn__img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #e8d5c0;
  box-shadow: 0 4rpx 16rpx rgba(139, 94, 60, 0.1);
}

.avatar-btn__empty {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #faf5ed 0%, #f5ead8 100%);
  border: 3rpx dashed #c8b89a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.avatar-btn__icon {
  font-size: 40rpx;
}

/* 头像右下角相机角标 */
.avatar-btn__badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 94, 60, 0.25);
}

/* 昵称输入框 */
.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #faf7f2;
  border: 2rpx solid #e8ddd0;
  font-size: 30rpx;
  color: #4a3728;
  text-align: center;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.nickname-input:focus {
  border-color: var(--color-primary);
  background: #fff;
  box-shadow: 0 0 0 6rpx rgba(192, 152, 128, 0.1);
}

.nickname-input::placeholder {
  color: #c4b8a8;
}

/* 隐藏昵称输入框（不可见但可聚焦以触发微信昵称获取） */
.nickname-input--hidden {
  position: absolute;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  padding: 0;
  border: none;
  pointer-events: none;
}

/* 昵称展示区（横向卡片右半部） */
.nickname-display {
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rpx 0;
  border-radius: 12rpx;
  min-height: 80rpx;
}

.nickname-display--waiting {
  border: 2rpx dashed #e0d6c8;
  padding: 16rpx 20rpx;
}

.nickname-display__icon {
  font-size: 22rpx;
}

.nickname-display__text {
  font-size: 30rpx;
  color: #4a3728;
  font-weight: 600;
  line-height: 1.4;
}

.nickname-display__hint {
  font-size: 22rpx;
  color: #8cb88e;
  margin-top: 4rpx;
}

.nickname-display--waiting .nickname-display__text {
  color: #b8a898;
  font-weight: 400;
  font-size: 28rpx;
}

/* ========================================
   微信登录按钮
   ======================================== */
.wechat-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #b89478 0%, #a07858 100%);
  color: #fff;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 20rpx rgba(160, 120, 88, 0.25);
  transition: all 0.15s;
}

.wechat-btn:active {
  transform: scale(0.98);
  opacity: 0.92;
  box-shadow: 0 2rpx 12rpx rgba(160, 120, 88, 0.15);
}

.wechat-btn--dark {
  background: linear-gradient(135deg, #6b4c3b 0%, #5a3a2a 100%);
  box-shadow: 0 4rpx 20rpx rgba(107, 76, 59, 0.2);
}

.wechat-btn__arrow {
  font-size: 32rpx;
  font-weight: 400;
}

.login-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #b8a898;
  margin-top: 16rpx;
}

.login-hint--ready {
  color: #a07858;
  font-weight: 500;
}

/* ========================================
   其他登录方式
   ======================================== */
.alt-login {
  width: 100%;
  margin-top: 48rpx;
}

.alt-login__divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.alt-login__line {
  flex: 1;
  height: 1rpx;
  background: #e0d6c8;
}

.alt-login__label {
  font-size: 24rpx;
  color: #b8a898;
  white-space: nowrap;
}

.alt-login__back {
  font-size: 24rpx;
  color: var(--color-primary);
  white-space: nowrap;
}

.alt-login__links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.alt-login__link {
  font-size: 28rpx;
  color: #a99b8c;
  padding: 8rpx 0;
}

.alt-login__link--active {
  color: var(--color-primary);
  font-weight: 600;
}

.alt-login__sep {
  font-size: 24rpx;
  color: #d4c8b8;
}

/* ========================================
   表单（邮箱/手机号）
   ======================================== */
.form-group {
  width: 100%;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8a7a6a;
  display: block;
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #e8ddd0;
  font-size: 30rpx;
  color: #4a3728;
  box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-input:focus {
  border-color: #c8a88a;
  box-shadow: 0 0 0 6rpx rgba(180, 140, 110, 0.1);
}

/* ========================================
   已登录状态
   ======================================== */
.logged-in-card {
  text-align: center;
  padding: 48rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 24rpx rgba(139, 94, 60, 0.06);
}

.logged-in__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  border: 3rpx solid #e8d5c0;
  box-shadow: 0 4rpx 12rpx rgba(139, 94, 60, 0.08);
}

.logged-in__avatar--placeholder {
  background: #faf5ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-left: auto;
  margin-right: auto;
}

.logged-in__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.logged-in__user {
  font-size: 26rpx;
  color: #a99b8c;
  display: block;
  margin: 8rpx 0 24rpx 0;
}

.logged-in__actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.login-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
  width: 100%;
}

.login-divider::before,
.login-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e0d6c8;
}

.login-divider text {
  font-size: 24rpx;
  color: #b8a898;
}

/* ========================================
   跳过
   ======================================== */
.skip-section {
  text-align: center;
  margin-top: auto;
  padding-top: 24rpx;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.skip-link {
  font-size: 28rpx;
  color: #a89a86;
  display: inline-block;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 2rpx solid #e0d6c8;
  transition: all 0.15s;
}

.skip-link:active {
  background: rgba(255, 255, 255, 0.8);
  border-color: #c8b89a;
  color: #8a7a6a;
}
