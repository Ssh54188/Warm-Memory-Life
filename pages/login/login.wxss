/* 登录页 — v1.0.2 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf7f2 0%, #f0ebe0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 var(--spacing-xl);
}

/* ========================================
   品牌区
   ======================================== */
.brand {
  text-align: center;
  padding-top: 48rpx;
  padding-bottom: 60rpx;
}

.brand__icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: var(--spacing-md);
}

.brand__title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.brand__desc {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  margin-top: var(--spacing-xs);
  display: block;
}

/* ========================================
   Tab 切换
   ======================================== */
.login-tabs {
  display: flex;
  background: var(--color-divider);
  border-radius: var(--radius-full);
  padding: 4rpx;
  margin-bottom: var(--spacing-xl);
  width: 100%;
}

.login-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  transition: all 0.15s;
}

.login-tab--active {
  background: var(--color-white);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* ========================================
   登录面板
   ======================================== */
.login-panel {
  width: 100%;
  max-width: 560rpx;
}

.login-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: 24rpx 0;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 500;
  border: none;
  transition: all 0.15s;
}

.login-btn:active {
  transform: scale(0.97);
}

.login-btn--wechat {
  background: #07c160;
  color: #fff;
}

.login-btn--phone {
  background: var(--color-primary);
  color: #fff;
}

.login-btn--email {
  background: var(--color-primary);
  color: #fff;
  margin-top: var(--spacing-md);
}

.login-btn__icon {
  font-size: 40rpx;
}

.login-hint {
  display: block;
  text-align: center;
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: var(--spacing-sm);
}

/* ========================================
   已登录状态
   ======================================== */
.logged-in-card {
  text-align: center;
  padding: var(--spacing-lg);
  background: var(--color-white);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  width: 100%;
  box-sizing: border-box;
}

.logged-in__icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: var(--spacing-sm);
}

.logged-in__title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.logged-in__user {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.logged-in__actions {
  display: flex;
  justify-content: center;
  gap: var(--spacing-sm);
}

.login-divider {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-lg);
  width: 100%;
}

.login-divider::before,
.login-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--color-divider);
}

.login-divider text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

/* ========================================
   邮箱表单
   ======================================== */
.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-base);
  box-sizing: border-box;
}

/* ========================================
   跳过
   ======================================== */
.skip-section {
  text-align: center;
  margin-top: auto;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.skip-link {
  font-size: var(--font-sm);
  color: var(--color-primary);
  display: block;
  padding: var(--spacing-md);
}

.skip-hint {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  display: block;
}
