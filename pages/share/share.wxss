/* pages/share/share.wxss */
.container { padding: 24rpx; min-height: 100vh; background: #f7f0e8; }
.header { margin-bottom: 32rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #4a3728; display: block; }
.subtitle { font-size: 26rpx; color: #8a7b6b; margin-top: 8rpx; display: block; }

.section { background: #fffdf9; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; border: 1rpx solid #e8ddd0; }
.section-title { font-size: 28rpx; font-weight: 600; color: #4a3728; margin-bottom: 16rpx; display: block; }

.partner-card { display: flex; justify-content: space-between; align-items: center; }
.partner-info { display: flex; flex-direction: column; gap: 8rpx; }
.partner-label { font-size: 24rpx; color: #8a7b6b; }
.partner-id { font-size: 26rpx; color: #4a3728; font-weight: 500; }

.btn-disable { font-size: 24rpx; color: #d95c5c; padding: 8rpx 20rpx; border: 1rpx solid #d95c5c; border-radius: 8rpx; }
.btn-disable:active { background: #fff0f0; }

.invite-type-selector { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.type-btn { flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx; font-size: 26rpx; color: #8a7b6b; background: #f7f0e8; border: 1rpx solid #e8ddd0; }
.type-btn--active { background: #d4a574; color: #fff; border-color: #d4a574; }

.invite-box { display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.btn-primary { background: #d4a574; color: #fff; font-size: 28rpx; padding: 16rpx 48rpx; border-radius: 12rpx; text-align: center; }
.btn-primary:active { background: #b8945a; }

.invite-code-box { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 24rpx; background: #fef9f0; border-radius: 12rpx; border: 1rpx dashed #d4a574; }
.invite-label { font-size: 24rpx; color: #8a7b6b; }
.invite-code { font-size: 48rpx; font-weight: 700; color: #d4a574; letter-spacing: 8rpx; }
.invite-tip { font-size: 22rpx; color: #a99b8c; text-align: center; }

.btn-secondary { background: #f7f0e8; color: #8a7b6b; font-size: 24rpx; padding: 12rpx 32rpx; border-radius: 8rpx; text-align: center; border: 1rpx solid #e8ddd0; }

.accept-box { display: flex; flex-direction: column; gap: 16rpx; }
.code-input { background: #f7f0e8; border: 1rpx solid #e8ddd0; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 32rpx; letter-spacing: 8rpx; text-align: center; }

.shared-preview { margin-top: 16rpx; }
.preview-label { font-size: 24rpx; color: #8a7b6b; margin-bottom: 12rpx; display: block; }
.preview-item { background: #f7f0e8; padding: 12rpx 16rpx; border-radius: 8rpx; margin-bottom: 8rpx; font-size: 26rpx; color: #4a3728; }
