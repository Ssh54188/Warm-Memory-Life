/* 分享页 — v1.0.3 统一设计系统 */
.container { padding: 24rpx; min-height: 100vh; background: var(--color-paper-dark); }
.header { margin-bottom: 32rpx; }
.title { font-size: 40rpx; font-weight: 700; color: var(--color-text); display: block; }
.subtitle { font-size: 26rpx; color: var(--color-text-secondary); margin-top: 8rpx; display: block; }

.section { background: var(--color-white); border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; border: 1rpx solid var(--color-border); }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 16rpx; display: block; }

.partner-card { display: flex; justify-content: space-between; align-items: center; }
.partner-info { display: flex; flex-direction: column; gap: 8rpx; }
.partner-label { font-size: 24rpx; color: var(--color-text-secondary); }
.partner-id { font-size: 26rpx; color: var(--color-text); font-weight: 500; }

.btn-disable { font-size: 24rpx; color: var(--color-danger); padding: 8rpx 20rpx; border: 1rpx solid var(--color-danger); border-radius: 8rpx; }
.btn-disable:active { background: var(--color-accent-peach); }

.invite-type-selector { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.type-btn { flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx; font-size: 26rpx; color: var(--color-text-secondary); background: var(--color-paper); border: 1rpx solid var(--color-border); }
.type-btn--active { background: var(--color-primary); color: var(--color-white); border-color: var(--color-primary); }

.invite-box { display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.btn-primary { background: var(--color-primary); color: var(--color-white); font-size: 28rpx; padding: 16rpx 48rpx; border-radius: 12rpx; text-align: center; }
.btn-primary:active { background: var(--color-primary-dark); }

.invite-code-box { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 24rpx; background: var(--color-surface-warm); border-radius: 12rpx; border: 1rpx dashed var(--color-primary); }
.invite-label { font-size: 24rpx; color: var(--color-text-secondary); }
.invite-code { font-size: 48rpx; font-weight: 700; color: var(--color-primary); letter-spacing: 8rpx; }
.invite-tip { font-size: 22rpx; color: var(--color-text-light); text-align: center; }

.btn-secondary { background: var(--color-paper); color: var(--color-text-secondary); font-size: 24rpx; padding: 12rpx 32rpx; border-radius: 8rpx; text-align: center; border: 1rpx solid var(--color-border); }

.accept-box { display: flex; flex-direction: column; gap: 16rpx; }
.code-input { background: var(--color-paper); border: 1rpx solid var(--color-border); border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 32rpx; letter-spacing: 8rpx; text-align: center; }

.shared-preview { margin-top: 16rpx; }
.preview-label { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; display: block; }
.preview-item { background: var(--color-paper); padding: 12rpx 16rpx; border-radius: 8rpx; margin-bottom: 8rpx; font-size: 26rpx; color: var(--color-text); }
