<!-- 个人资料页 -->
<view class="page">
  <scroll-view class="page__body" scroll-y>

    <!-- 头像行 -->
    <view class="profile-row" bindtap="onAvatarTap">
      <text class="profile-row__label">头像</text>
      <view class="profile-row__value profile-row__value--avatar">
        <image
          wx:if="{{userInfo.avatarUrl}}"
          class="profile-avatar"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="profile-avatar profile-avatar--placeholder">👤</view>
        <text class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 用户ID行 -->
    <view class="profile-row">
      <text class="profile-row__label">用户ID</text>
      <text class="profile-row__value">{{userId}}</text>
    </view>

    <!-- 昵称行 -->
    <view class="profile-row" bindtap="onNicknameTap">
      <text class="profile-row__label">昵称</text>
      <view class="profile-row__value profile-row__value--link">
        <text>{{userInfo.nickName || '未设置'}}</text>
        <text class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 手机号行 -->
    <view class="profile-row">
      <text class="profile-row__label">手机号</text>
      <view class="profile-row__value profile-row__value--link">
        <text>{{userInfo.phone || '未绑定'}}</text>
        <text wx:if="{{!userInfo.phone}}" class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 微信行 -->
    <view class="profile-row">
      <text class="profile-row__label">微信</text>
      <text class="profile-row__value">{{userInfo.wechatName || '未绑定'}}</text>
    </view>

    <!-- 性别行 -->
    <view class="profile-row">
      <text class="profile-row__label">性别</text>
      <view class="profile-row__value profile-row__value--link">
        <text>{{userInfo.gender || '未填写'}}</text>
        <text class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 年龄行 -->
    <view class="profile-row">
      <text class="profile-row__label">年龄</text>
      <view class="profile-row__value profile-row__value--link">
        <text>{{userInfo.age || '未填写'}}</text>
        <text class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 职业行 -->
    <view class="profile-row">
      <text class="profile-row__label">职业</text>
      <view class="profile-row__value profile-row__value--link">
        <text>{{userInfo.occupation || '未填写'}}</text>
        <text class="profile-row__arrow">›</text>
      </view>
    </view>

    <!-- 提示文字 -->
    <view class="profile-tip">
      <text>完善资料可解锁更多功能</text>
    </view>

    <!-- 退出登录 -->
    <view class="profile-btn profile-btn--danger" bindtap="onLogout">
      <text>退出登录</text>
    </view>

    <!-- 账号注销 -->
    <view class="profile-btn profile-btn--ghost" bindtap="onDeleteAccount">
      <text>账号注销</text>
    </view>

    <!-- 底部占位 -->
    <view class="profile-footer"></view>
  </scroll-view>

  <!-- 昵称编辑弹窗 -->
  <view wx:if="{{showEditNickname}}" class="nickname-modal-mask" bindtap="onCancelNickname">
    <view class="nickname-modal" catchtap>
      <text class="nickname-modal__title">修改昵称</text>
      <input
        class="nickname-modal__input"
        type="text"
        value="{{editNicknameValue}}"
        bindinput="onEditNicknameInput"
        placeholder="请输入新昵称"
        maxlength="20"
        focus="{{showEditNickname}}"
        confirm-type="done"
        bindconfirm="onConfirmNickname"
      />
      <view class="nickname-modal__actions">
        <view class="nickname-modal__btn nickname-modal__btn--cancel" bindtap="onCancelNickname">取消</view>
        <view class="nickname-modal__btn nickname-modal__btn--confirm" bindtap="onConfirmNickname">确定</view>
      </view>
    </view>
  </view>
</view>
