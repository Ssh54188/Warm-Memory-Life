/* 个人中心 — v1.0.2 */
.page {
  min-height: 100vh;
  background: var(--color-paper);
}

.page__body {
  padding-top: var(--spacing-md);
}

/* ========================================
   用户卡片
   ======================================== */
.user-card {
  background: var(--color-white);
  margin: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-lg) var(--spacing-md);
}

.user-info {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar--placeholder {
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.user-sub {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  display: block;
  margin-top: 4rpx;
}

.user-arrow {
  font-size: var(--font-lg);
  color: var(--color-text-light);
}

/* ========================================
   菜单
   ======================================== */
.menu-section {
  background: var(--color-white);
  margin: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  border-bottom: 1rpx solid var(--color-divider);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-paper);
}

.menu-item__icon {
  font-size: 36rpx;
}

.menu-item__label {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
}

.menu-item__arrow {
  font-size: var(--font-lg);
  color: var(--color-text-light);
}

.menu-item__hint {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

/* ========================================
   存储 & 退出 & 页脚
   ======================================== */
.storage-info {
  text-align: center;
  padding: var(--spacing-md);
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

.logout-section {
  display: flex;
  justify-content: center;
  padding: var(--spacing-md);
}

.footer {
  text-align: center;
  padding: var(--spacing-xl) 0 calc(var(--spacing-xl) + env(safe-area-inset-bottom));
  font-size: var(--font-xs);
  color: var(--color-text-light);
}
