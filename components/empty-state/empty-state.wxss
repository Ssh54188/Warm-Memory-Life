/* 空状态组件 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-state__icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-state__text {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  text-align: center;
  line-height: 1.8;
}

.empty-state__btn {
  margin-top: var(--spacing-lg);
}
